    {
      "parameters": {
        "jsCode": "function findString(value) {\n  if (typeof value === 'string') {\n    if (value.includes('product_name')) return value;\n    return null;\n  }\n\n  if (Array.isArray(value)) {\n    for (const v of value) {\n      const found = findString(v);\n      if (found) return found;\n    }\n    return null;\n  }\n\n  if (value && typeof value === 'object') {\n    for (const key of Object.keys(value)) {\n      const found = findString(value[key]);\n      if (found) return found;\n    }\n  }\n\n  return null;\n}\n\nconst item = $input.first().json;\nlet raw = findString(item);\n\nif (!raw) {\n  throw new Error('Heç bir JSON-a bənzər text tapılmadı');\n}\n\nraw = String(raw).trim();\n\n// 1) əgər code block varsa sil\nraw = raw\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '');\n\n// 2) əgər string içində literal \\n varsa, normal newline et\nraw = raw.replace(/\\\\n/g, '\\n');\n\n// 3) ilk { tap\nconst start = raw.indexOf('{');\nif (start === -1) {\n  throw new Error('Başlanğıc { tapılmadı. Raw: ' + raw);\n}\n\nraw = raw.slice(start);\n\n// 4) əgər son } yoxdursa, əlavə et\nif (!raw.trim().endsWith('}')) {\n  raw = raw.trim() + '}';\n}\n\nlet data;\n\n// 5) birbaşa parse cəhdi\ntry {\n  data = JSON.parse(raw);\n} catch (e1) {\n  try {\n    // 6) bəzən bu JSON string olur, iki dəfə parse lazımdır\n    const tmp = JSON.parse(raw);\n    data = typeof tmp === 'string' ? JSON.parse(tmp) : tmp;\n  } catch (e2) {\n    throw new Error('Parse alınmadı. Raw: ' + raw);\n  }\n}\n\nreturn [\n  {\n    json: {\n      product_name: data.product_name ?? '',\n      short_title: data.short_title ?? '',\n      description: data.description ?? '',\n      category: data.category ?? '',\n      ad_caption: data.ad_caption ?? '',\n      image_prompt: data.image_prompt ?? '',\n      video_prompt: data.video_prompt ?? '',\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
